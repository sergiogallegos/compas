{
  "id": "korg-nanokontrol2",
  "name": "Korg nanoKONTROL2",
  "ports": { "input": "nanoKONTROL2", "output": "nanoKONTROL2" },
  "bindings": [
    { "channel": 0, "input": { "kind": "cc", "cc": 0 },  "control": "deck.0.gain",   "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 1 },  "control": "deck.1.gain",   "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 2 },  "control": "deck.2.gain",   "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 3 },  "control": "deck.3.gain",   "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 7 },  "control": "mixer.master_gain", "soft_takeover": true },

    { "channel": 0, "input": { "kind": "cc", "cc": 16 }, "control": "deck.0.filter", "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 17 }, "control": "deck.1.filter", "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 18 }, "control": "deck.2.filter", "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 19 }, "control": "deck.3.filter", "soft_takeover": true },
    { "channel": 0, "input": { "kind": "cc", "cc": 23 }, "control": "mixer.crossfader", "soft_takeover": true },

    { "channel": 0, "input": { "kind": "cc", "cc": 32 }, "control": "deck.0.cue" },
    { "channel": 0, "input": { "kind": "cc", "cc": 33 }, "control": "deck.1.cue" },
    { "channel": 0, "input": { "kind": "cc", "cc": 34 }, "control": "deck.2.cue" },
    { "channel": 0, "input": { "kind": "cc", "cc": 35 }, "control": "deck.3.cue" },

    { "channel": 0, "input": { "kind": "cc", "cc": 48 }, "control": "deck.0.sync" },
    { "channel": 0, "input": { "kind": "cc", "cc": 49 }, "control": "deck.1.sync" },
    { "channel": 0, "input": { "kind": "cc", "cc": 50 }, "control": "deck.2.sync" },
    { "channel": 0, "input": { "kind": "cc", "cc": 51 }, "control": "deck.3.sync" }
  ]
}
