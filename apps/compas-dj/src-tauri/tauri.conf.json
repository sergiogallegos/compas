{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compás DJ",
  "mainBinaryName": "compas-dj",
  "version": "0.1.0",
  "identifier": "com.compas.dj",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Compás DJ",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/controllers/*"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sergiogallegos/compas/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyRDA5RTNCMjIyQzBCRDIKUldUU0N5d2lPNTdRZ3I2RHZ1RGRNTStIWTA0V2phR0hma1BiMzF2Y2VqVWJILzhXUUVidkp3TzYK"
    }
  }
}
